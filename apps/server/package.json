{
	"name": "@nano-agent/server",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "sh -c 'if [ -f ../../.env ]; then tsx watch --env-file=../../.env src/index.ts; else tsx watch src/index.ts; fi'",
		"build": "tsc",
		"start": "node dist/index.js",
		"seed": "tsx src/seed.ts",
		"clean": "rm -rf dist .turbo"
	},
	"dependencies": {
		"@hono/node-server": "^1.13.7",
		"@hono/zod-validator": "^0.4.2",
		"@langchain/anthropic": "^1.3.25",
		"@langchain/core": "^1.1.34",
		"@langchain/langgraph": "^1.2.3",
		"@langchain/mcp-adapters": "^1.1.3",
		"@langchain/openai": "^1.3.0",
		"@nano-agent/db": "workspace:*",
		"@nano-agent/shared": "workspace:*",
		"adm-zip": "^0.5.16",
		"deepagents": "^1.8.4",
		"drizzle-orm": "^0.38.3",
		"gray-matter": "^4.0.3",
		"hono": "^4.6.14",
		"langchain": "^1.2.34",
		"pdf-parse": "^2.4.5",
		"zod": "^3.24.1"
	},
	"devDependencies": {
		"@types/adm-zip": "^0.5.8",
		"@types/node": "^22.10.5",
		"@types/pdf-parse": "^1.1.5",
		"tsx": "^4.19.2",
		"typescript": "^5.7.3"
	}
}
