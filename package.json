{
	"name": "nano-agent",
	"private": true,
	"scripts": {
		"dev": "turbo dev",
		"build": "turbo build",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"db:generate": "turbo db:generate --filter=@nano-agent/db",
		"db:push": "turbo db:push --filter=@nano-agent/db",
		"db:studio": "turbo db:studio --filter=@nano-agent/db",
		"seed": "pnpm -r --filter @nano-agent/server run seed",
		"test": "turbo test",
		"clean": "turbo clean && rm -rf node_modules"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"turbo": "^2.3.3",
		"typescript": "^5.7.3"
	},
	"packageManager": "pnpm@9.15.4",
	"engines": {
		"node": ">=20"
	}
}
